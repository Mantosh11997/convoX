<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center_horizontal"
    android:padding="28dp">

    <TextView
        android:id="@+id/tvAvatar"
        android:layout_width="110dp" android:layout_height="110dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/circle_avatar_bg" android:gravity="center"
        android:textColor="@color/white" android:textSize="42sp" android:textStyle="bold" />

    <TextView
        android:id="@+id/tvUsername"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textColor="@color/black" android:textSize="24sp" android:textStyle="bold" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="4dp" android:text="Online"
        android:textColor="@color/online_green" />

    <TextView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="36dp" android:text="About"
        android:textColor="@color/wa_dark_green" android:textStyle="bold" />

    <EditText
        android:id="@+id/etAbout"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:padding="16dp"
        android:background="@drawable/bg_input"
        android:hint="Hey there! I am using convoX."
        android:textColor="@color/black" android:textColorHint="@color/wa_gray_text"
        android:maxLines="3" />

    <Button
        android:id="@+id/btnSaveAbout"
        android:layout_width="match_parent" android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_button_gradient"
        android:text="Save" android:textAllCaps="false" android:textColor="@color/white" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent" android:layout_height="50dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_button_outline"
        android:text="Log Out" android:textAllCaps="false" android:textColor="@color/wa_red" />

</LinearLayout>
