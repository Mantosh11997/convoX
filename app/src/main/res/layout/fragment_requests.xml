<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroup"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_margin="14dp"
        app:singleSelection="true" app:selectionRequired="true"
        app:checkedButton="@id/btnReceived">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReceived" style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Received" android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSent" style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Sent" android:textAllCaps="false" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRequests"
            android:layout_width="match_parent" android:layout_height="match_parent" />
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:gravity="center"
            android:text="No pending friend requests"
            android:textColor="@color/wa_gray_text" android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
