<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="20dp">

    <TextView
        android:id="@+id/rowAccount"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="18dp" android:background="@drawable/bg_input"
        android:text="Account\nYour username and login details"
        android:textColor="@color/black" android:lineSpacingExtra="4dp" />

    <TextView
        android:id="@+id/rowNotifications"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:padding="18dp" android:background="@drawable/bg_input"
        android:text="Notifications\nComing soon"
        android:textColor="@color/black" android:lineSpacingExtra="4dp" />

    <TextView
        android:id="@+id/rowAbout"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:padding="18dp" android:background="@drawable/bg_input"
        android:text="About\nconvoX v1.0 — built with Supabase"
        android:textColor="@color/black" android:lineSpacingExtra="4dp" />

</LinearLayout>
